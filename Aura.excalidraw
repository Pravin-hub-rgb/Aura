      "boundElements": [],
      "updated": 1774801452060,
      "link": null,
      "locked": false,
      "text": "But now, the moment you stop apologizing for your power,\nthe moment you stop minimizing your potential, \nthe moment you decide to no longer entertain lack,\ngossip, or emotional chaos,\nthat is the moment your aura becomes undeniable. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "sXvLlVHrs5blD9hBGzZEQ",
      "originalText": "But now, the moment you stop apologizing for your power, \nthe moment you stop minimizing your potential, \nthe moment you decide to no longer entertain lack, gossip, or emotional chaos,\nthat is the moment your aura becomes undeniable. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
