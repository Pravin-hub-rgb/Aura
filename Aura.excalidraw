      "boundElements": [],
      "updated": 1775007594941,
      "link": null,
      "locked": false,
      "text": "Two. Alignment. Affirmation. \nSpeak to your nervous system. Not to impress, but to\nrewire. \nTell your body how it feels when you're already wealthy. \nSay, I am safe. \nI am trusted. \nI am responsible with abundance. \nI am a vessel for impact.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "TzFnmAvDnhd1KjtKyU-wF",
      "originalText": "Two. Alignment. Affirmation. \nSpeak to your nervous system. Not to impress, but to rewire. \nTell your body how it feels when you're already wealthy. \nSay, I am safe. \nI am trusted. \nI am responsible with abundance. \nI am a vessel for impact.",
      "autoResize": true,
      "lineHeight": 1.25
    },
