    {
      "id": "YV5UhPhbWHlj8y48rUzLA",
      "type": "text",
      "x": 6588.5,
      "y": -27885,
      "width": 583,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
