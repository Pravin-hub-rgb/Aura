    {
      "id": "zyd4FximTRIuclEtEPVOF",
      "type": "text",
      "x": 9823.16015625,
      "y": -46120,
      "width": 553.6796875,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
