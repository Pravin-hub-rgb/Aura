      "boundElements": [],
      "updated": 1774801626779,
      "link": null,
      "locked": false,
      "text": "Declare every day, \nI am wealth in motion. \nI am aligned with abundance. \nI do not chase, I attract. \nI release guilt and embrace expansion. \nSay these not to impress the world, \nbut to reprogram yourself. \nAnd finally, trust this.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "bqoz2myfdB0R2fMEdsy96",
      "originalText": "Declare every day, \nI am wealth in motion. \nI am aligned with abundance. \nI do not chase, I attract. \nI release guilt and embrace expansion. \nSay these not to impress the world, \nbut to reprogram yourself. \nAnd finally, trust this.",
      "autoResize": true,
      "lineHeight": 1.25
    },
