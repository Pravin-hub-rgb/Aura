      "isDeleted": false,
      "boundElements": [],
      "updated": 1775007209312,
      "link": null,
      "locked": false,
      "text": "You must reclaim authorship of your identity. \nYou must erase the story that was written for you \nby broke parents, \ninsecure teachers, \ncautious friends, \nand a society that glorifies struggle. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "cwSwqDKC8ztVbAGbGt2-b",
      "originalText": "You must reclaim authorship of your identity. \nYou must erase the story that was written for you \nby broke parents, \ninsecure teachers, \ncautious friends, \nand a society that glorifies struggle. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
