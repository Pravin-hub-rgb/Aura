      "link": null,
      "locked": false,
      "text": "every time you think a thought, \nevery time you hold a belief, \nevery time you speak words out loud. \nEvery single one of these becomes part of\nthe field around you. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "k3wApCjjdrGV2hqxT4ofw",
      "originalText": "every time you think a thought, \nevery time you hold a belief, \nevery time you speak words out loud. \nEvery single one of these becomes part of the field around you. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
