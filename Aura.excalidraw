      "isDeleted": false,
      "boundElements": [],
      "updated": 1775007209312,
      "link": null,
      "locked": false,
      "text": "You are not born poor. \nYou are trained to think poor. \nYou are conditioned to fear wealth, \nto associate with it. it with guilt,\ngreed, or corruption.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "FD11kv2lEBl9XF_w8xkNK",
      "originalText": "You are not born poor. \nYou are trained to think poor. \nYou are conditioned to fear wealth, \nto associate with it. it with guilt, greed, or corruption.",
      "autoResize": true,
      "lineHeight": 1.25
    },
