    {
      "id": "SVaTZZe36m_g_tUcNTV83",
      "type": "text",
      "x": 8505,
      "y": -32897.5,
      "width": 470.499755859375,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
