      "link": null,
      "locked": false,
      "text": "It is shaped by every thought, word, and\naction. \nYou are always training it, consciously or\nunconsciously. \nSo train it with intent.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Kkcku_Uu9bfuCuSTY_vCl",
      "originalText": "It is shaped by every thought, word, and action. \nYou are always training it, consciously or unconsciously. \nSo train it with intent.",
      "autoResize": true,
      "lineHeight": 1.25
    },
