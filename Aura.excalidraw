      "updated": 1774972343234,
      "link": null,
      "locked": false,
      "text": "Before any important meeting,\nconversation, decision, or performance, sit\nstill.\nClose your eyes, breathe deeply, and imagine\nit already went better than expected. Feel\nthe applause. \nFeel the relief. Feel the confirmation.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "lALAROahV3hoGVw_K_OGS",
      "originalText": "Before any important meeting, conversation, decision, or performance, sit still.\nClose your eyes, breathe deeply, and imagine it already went better than expected. Feel the applause. \nFeel the relief. Feel the confirmation.",
      "autoResize": true,
      "lineHeight": 1.25
    },
